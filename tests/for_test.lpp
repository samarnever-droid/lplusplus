def main():
    print_str("--- For Loop Syntactic Sugar Test ---")
    
    mut l := list_new()
    list_push(l, 10)
    list_push(l, 20)
    list_push(l, 30)
    
    for x in l:
        print(x)
        
    # List[Int] is automatically released by the ownership runtime.
    print_str("--- Success ---")
