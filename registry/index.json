        "max": "(a: Int, b: Int) -> Int",
        "clamp": "(x: Int, lo: Int, hi: Int) -> Int",
        "pow": "(base: Int, exp: Int) -> Int",
        "gcd": "(a: Int, b: Int) -> Int",
        "fib": "(n: Int) -> Int",
        "factorial": "(n: Int) -> Int",
        "is_even": "(x: Int) -> Bool",
        "is_odd": "(x: Int) -> Bool"
      }
