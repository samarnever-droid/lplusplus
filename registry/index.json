  "packages": {
    "lpp-zip": {
      "name": "lpp-zip",
      "version": "0.1.0",
      "description": "ZIP archive create/read library — pure L++ using buf_* binary primitives",
      "authors": ["0x4171341"],
      "license": "MIT",
      "repository": "https://github.com/samarnever-droid/lplusplus",
      "source_path": "packages/lpp-zip/src/zip.lpp",
      "source_url": "https://raw.githubusercontent.com/samarnever-droid/lplusplus/master/packages/lpp-zip/src/zip.lpp",
      "dependencies": [],
      "keywords": ["zip", "archive", "binary", "file"],
      "api": {
        "zip_create": "() -> Int",
        "zip_add_file": "(archive: Int, filename: Str, content: Str)",
        "zip_save": "(archive: Int, path: Str)",
        "zip_free": "(archive: Int)",
        "zip_open": "(path: Str) -> Int",
        "zip_entry_count": "(handle: Int) -> Int",
        "zip_entry_name": "(handle: Int, index: Int) -> Str",
        "zip_entry_data": "(handle: Int, index: Int) -> Str",
        "zip_close": "(handle: Int)"
      }
    },
