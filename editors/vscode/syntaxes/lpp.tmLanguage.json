{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "L++",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#builtins" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.lpp",
                    "match": "#.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.lpp",
                    "match": "\\b(def|struct|fn|return|spawn|if|else|while|mut)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.lpp",
                    "match": "\\b(Int|String|Bool|Void)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.lpp",
                    "match": "\\b(print|print_str|input|read_file|write_file)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.lpp",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.lpp",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.lpp",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.lpp",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.lpp",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.lpp",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.comparison.lpp",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.arithmetic.lpp",
                    "match": "\\+|-|\\*|/"
                },
                {
                    "name": "keyword.operator.arrow.lpp",
                    "match": "->"
                }
            ]
        }
    ],
    "scopeName": "source.lpp"
}
