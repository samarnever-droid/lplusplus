--- lpp_runtime.c.orig  2026-07-21 00:00:00.000000000 +0000
+++ lpp_runtime.c       2026-07-21 00:00:00.000000000 +0000
@@ -807,3 +807,13 @@ void lpp_net_close(int64_t handle) {
     lpp__socket_clear(handle);
 }
 
+/* Helper: duplicate string via malloc (avoids POSIX strdup) */
+static char* lpp_strdup(const char *s) {
+    if (!s) return NULL;
+    size_t len = strlen(s);
+    char *d = (char *)malloc(len + 1);
+    if (d) { memcpy(d, s, len); d[len] = 0; }
+    return d;
+}
+#define strdup lpp_strdup
+
