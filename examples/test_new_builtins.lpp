def main():
    print_str("=== Testing 15 New L++ Standard Builtins ===")

    # 1. String operations
    s1 := "Hello"
    s2 := "World"
    greeting := str_concat(s1, " ")
    full_greeting := str_concat(greeting, s2)
    print_str("1. Concat result:")
    print_str(full_greeting)

    # 2. Path & File System operations
    test_dir := "lpp_test_demo_folder"
    print_str("2. Creating directory...")
    dir_create(test_dir)
    
    exists := path_exists(test_dir)
    print_str("3. Path exists check:")
    print(exists)

    # 3. Subprocess & Command Output
    print_str("4. Command Output (hostname):")
    out := command_output("hostname")
    print_str(out)

    # 4. Clean up test dir
    dir_remove(test_dir)
    print_str("5. Cleaned up test folder!")
    print_str("=== All 15 New Builtins Functioning 100%! ===")
