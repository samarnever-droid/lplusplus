def handle_worker(client: Int) -> Int:
    if client >= 0:
        msg := net_recv(client, 512)
        if list_len(msg) > 0:
            net_send_all(client, "OK:")
            net_send_all(client, msg)
        net_close(client)
    return 0

def main():
    print_str("[L++] Starting High-Concurrency TCP Stress Server on port 9090...")
    listener := net_listen(9090)
    print_str("[L++] Server listening on port 9090 (fd:")
    print(listener)

    mut count := 0
    while count < 50:
        client := net_accept(listener)
        if client >= 0:
            count = count + 1
            spawn fn(): handle_worker(client)

    print_str("[L++] Processed 50 connections successfully!")
    net_close(listener)
