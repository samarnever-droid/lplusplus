def test_value211() -> Int:
    n := BasicNode211()
    return n.value

def test_rule1_211() -> BasicNode211:
    n := BasicNode211()
    return n

def test_rule2_211() -> Void:
    x := 100
    f := fn(y: Int) -> Int:
        return x + y

def test_rule4_211() -> Void:
    shared := BasicNode211()
    spawn fn() -> Void:
        print(shared.value)

struct RecNode211:
    value: Int
    next: RecNode211

def test_rule5_211() -> Void:
    r := RecNode211()

def test_ifelse_211() -> Void:
    if 1 == 1:
        print(1)
    else:
        print(0)

def test_while_211() -> Void:
    mut count := 0
    while count < 10:
        count = count + 1

def test_nested_closures_211() -> Void:
    x := 10
    f := fn() -> Void:
        y := 20
        g := fn() -> Void:
            print(x + y)

def test_rule3_211() -> Void:
    n := BasicNode211()
    lst := [n]

def test_relational_211() -> Void:
    a := 5
    b := 10
    c := a < b

