    r := RecNode422()

def test_ifelse_422() -> Void:
    if 1 == 1:
        print(1)
    else:
        print(0)

def test_while_422() -> Void:
    mut count := 0
    while count < 10:
        count = count + 1

def test_nested_closures_422() -> Void:
    x := 10
    f := fn() -> Void:
        y := 20
        g := fn() -> Void:
            print(x + y)

def test_rule3_422() -> Void:
    n := BasicNode422()
    lst := [n]

def test_relational_422() -> Void:
