    n := BasicNode422()
    return n.value

def test_rule1_422() -> BasicNode422:
    n := BasicNode422()
    return n

def test_rule2_422() -> Void:
    x := 100
    f := fn(y: Int) -> Int:
        return x + y

def test_rule4_422() -> Void:
    shared := BasicNode422()
    spawn fn() -> Void:
        print(shared.value)

